# Harness environment configuration
# Copy to .env and fill in values

# ── API Server ─────────────────────────────────────────────
HARNESS_HOST=localhost
HARNESS_PORT=9100
HARNESS_DEBUG=true

# ── Vite Dev Server ────────────────────────────────────────
VITE_HOST=localhost
VITE_PORT=9102

# ── Security ───────────────────────────────────────────────
# Comma-separated list of allowed origins for CORS.
ALLOWED_ORIGINS=http://localhost:9102,tauri://localhost,http://localhost:1420

# ── AI Engine (DSPy) ───────────────────────────────────────
# Primary LM provider: "ollama" | "anthropic" | "openai"
# Default is Ollama (local) so the harness works out-of-the-box without API keys.
DSPY_LM_PROVIDER=ollama
DSPY_LM_MODEL=llama3.2

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (optional fallback)
OPENAI_API_KEY=sk-...

# Ollama (optional local)
OLLAMA_BASE_URL=http://localhost:11434

# ── State Persistence ──────────────────────────────────────
STATE_DB_PATH=.harness/state.db
LOG_DIR=.harness/logs

# ── VLoop Data Layer ───────────────────────────────────────
# SQLite (default — file created automatically in .vloop/):
# VLOOP_DB_URL=
# PostgreSQL override:
# VLOOP_DB_URL=postgresql+asyncpg://user:password@localhost/vloop
#
# Override project .vloop directory location (defaults to CWD/.vloop):
# VLOOP_PROJECT_DIR=/custom/path

# ── Tools / Security Policy ────────────────────────────────
# Override the path to the project-local policy file
# (defaults to <workspace_root>/.vloop/policy.json):
# TOOLS_POLICY_PATH=/custom/path/policy.json

## ── Language Model ──────────────────────────────────────────────────────────
LM_PROVIDER=ollama              # ollama | openai | anthropic | lmstudio
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-haiku-20240307
LMSTUDIO_BASE_URL=http://localhost:1234

## ── Server ──────────────────────────────────────────────────────────────────
PORT=47201
HARNESS_CORE_URL=http://localhost:47200

## ── Database ────────────────────────────────────────────────────────────────
# DB_ENGINE=sqlite   → agent run data persists via harness-core REST API
#                      (same SQLite that the Tauri UI reads).  Default.
# DB_ENGINE=postgres → persists directly to Postgres (requires POSTGRES_URL).
DB_ENGINE=sqlite
POSTGRES_URL=postgresql://user:password@localhost:5432/vloop

## ── Security ────────────────────────────────────────────────────────────────
# SANDBOX_MODE=strict      → shell_exec uses list-form subprocess (no shell=True)
# SANDBOX_MODE=permissive  → shell_exec uses shell=True (development default)
SANDBOX_MODE=strict

# LAN host HMAC secret — set this in production to a stable secret so tokens
# survive inference-backend restarts.  If unset, harness-core auto-generates
# one per-installation (persisted in app_config SQLite table).
VLOOP_LAN_SECRET=

# VFS root — all FS IPC commands reject paths outside this directory.
# Defaults to $HOME when unset.  Set to the project workspace root in CI.
VLOOP_VFS_ROOT=

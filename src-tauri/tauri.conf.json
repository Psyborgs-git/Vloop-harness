{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vloop Harness",
  "version": "0.2.0",
  "identifier": "com.vloop.harness",
  "build": {
    "frontendDist": "../src-tauri/static",
    "devUrl": "vloop://settings",
    "beforeDevCommand": "",
    "beforeBuildCommand": "cd react && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Vloop Harness",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 1024,
        "minHeight": 768
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13"
    }
  }
}
